# Omni-Dash 환경변수 템플릿
# 사용법: `cp .env.example .env` 후 값 수정

# ========== Database ==========
POSTGRES_DB=omnidash
POSTGRES_USER=omnidash
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_PORT=5432

# ========== Backend (Spring Boot) ==========
BACKEND_PORT=18080
SPRING_PROFILES_ACTIVE=docker
# JVM heap (compose의 backend 서비스에 전달)
JAVA_OPTS=-Xms256m -Xmx768m
# 익명 세션 쿠키 만료 (초). 24h = 86400
SESSION_TTL_SECONDS=86400
# CORS 허용 오리진 (콤마 구분, 프론트 도메인)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ========== Frontend (Next.js) ==========
FRONTEND_PORT=3000
# 브라우저가 호출할 백엔드 (서버 사이드 호출이 아니라 클라이언트 호출이므로 외부 도메인)
NEXT_PUBLIC_API_BASE_URL=http://localhost:18080
# Next.js 서버 사이드 호출용 (compose 네트워크 내부 이름)
INTERNAL_API_BASE_URL=http://backend:8080

# ========== Skills ==========
# Skills.md 임계값을 외부에서 핫리로드할 디렉토리.
# 비워두면 jar 안의 기본값(application 자원) 사용.
SKILLS_CONFIG_PATH=
